---
import Layout from "../layouts/Layout.astro";

const LINKS = [
    {
        href: "https://www.youtube.com/watch?v=SF4m23No2Gg",
        title: "How Small Teams Can Build and Sell to Much Larger Enterprises - ELC 2024",
        description:
            "A talk I gave at ELC 2024 based on my experience building and selling enterprise software at Warrant",
    },
    {
        href: "https://www.youtube.com/watch?v=TqDeVght6d0",
        title: "Fine-Grained Authorization - ERC 2024",
        description:
            "A talk I gave at WorkOS's ERC 2024 conference about fine-grained authorization",
    },
];
---

<Layout>
    <h1 class="mb-8 text-2xl font-semibold">Aditya Kajla</h1>
    <p class="mb-4">
        👋 I&apos;m Aditya. I&apos;m an entrepreneur, and software engineer
        based in California, building <a
            class="underline"
            target="_blank"
            rel="noopener noreferrer"
            href="https://radialhq.ai">Radial</a
        >.
    </p>
    <p class="mb-4">
        I previously co-founded <a
            class="underline"
            target="_blank"
            rel="noopener noreferrer"
            href="https://www.ycombinator.com/companies/warrant">Warrant</a
        >, which was acquired by WorkOS in 2024. Prior to Warrant, I built
        software products and infrastructure at Lyft, Medallia, and Yahoo.
    </p>
    <p class="mb-16">
        Topics (sometimes unrelated) I&apos;m interested in: AI/LLMs, software
        infrastructure, distributed systems, databases, devtools, finance, NBA
        basketball (Lakers), and tennis.
    </p>
    <h2 class="mb-4 text-lg font-semibold">Links</h2>
    <ul class="space-y-6">
        {
            LINKS.map((link) => (
                <li>
                    <a
                        href={link.href}
                        class="hover:underline"
                        {...(link.href.startsWith('http') ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                    >
                        {link.title}
                    </a>
                    <p class="text-sm mt-1 text-neutral-500 dark:text-neutral-400">
                        {link.description}
                    </p>
                </li>
            ))
        }
    </ul>
</Layout>
